<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive database and preferences from system backup -->
        <!-- MemPass uses its own encrypted backup mechanism to Google Drive -->
        <exclude domain="database" path="mempass_vault.db"/>
        <exclude domain="sharedpref" path="mempass_security_v1.xml"/>
        <exclude domain="sharedpref" path="mempass_history_v1.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Allow transfer to new device during setup, but keep it secure -->
        <include domain="database" path="mempass_vault.db"/>
        <include domain="sharedpref" path="mempass_security_v1.xml"/>
    </device-transfer>
</data-extraction-rules>